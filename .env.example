# Скопировать в .env и заполнить:
#   cp .env.example .env

# Профиль города — имя файла без расширения из папки config/
# Примеры: city_profile_omsk, city_profile_kemerovo
CITY_PROFILE=city_profile

# Ключ 2GIS API — нужен для карты и геокодирования адресов
# Получить бесплатно: https://platform.2gis.ru
TWOGIS_API_KEY=

# Ключ CityAir API — опционально, для телеметрии датчиков качества воздуха
# Если не задан — используются данные Open-Meteo (бесплатно)
CITYAIR_API_KEY=
