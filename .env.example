# NSK OpenData Bot — переменные окружения
# Скопируйте в .env и заполните нужные значения.
# Файл .env НЕ коммитится в репозиторий (добавлен в .gitignore).

# ── CityAir API (опционально) ─────────────────────────────────────────────────
# Требуется для получения данных с физических станций мониторинга CityAir.
# Без этих переменных бот использует только Open-Meteo (бесплатно, без ключа).
# Ключ и URL предоставляются поставщиком CityAir.
CITYAIR_API_KEY=
CITYAIR_API_URL=

# ── Open-Meteo (ключ не требуется) ───────────────────────────────────────────
# Open-Meteo — открытый бесплатный API, работает без регистрации.
# Изменять не нужно, здесь только для документации.
# OPENMETEO_AQ_URL=https://air-quality-api.open-meteo.com/v1/air-quality
# OPENMETEO_WEATHER_URL=https://api.open-meteo.com/v1/forecast
